<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/..\FrameXML\UI.xsd">

  <Frame name="TurtleRP_MinimapIcon" movable="true" toplevel="true" enableMouse="true">
    <Size>
      <AbsDimension x="32" y="32" />
    </Size>
    <Anchors>
      <Anchor point="CENTER" relativeTo="MinimapCluster" relativePoint="CENTER">
        <Offset>
          <AbsDimension x="-40" y="0" />
        </Offset>
      </Anchor>
    </Anchors>

    <Frames>
      <Button name="$parent_OpenAdmin" enableMouse="true">
        <Size x="32" y="32"/>
        <Anchors>
          <Anchor point="CENTER" relativeTo="$parent" relativePoint="CENTER">
            <Offset>
              <AbsDimension x="0" y="0" />
            </Offset>
          </Anchor>
        </Anchors>

        <Layers>
          <Layer level="BACKGROUND">
            <Texture name="$parentEye" file="Interface\Addons\TurtleRP\images\wizardturtle-round">
              <Size x="16" y="16"/>
              <Anchors>
                <Anchor point="CENTER">
                  <Offset x="0" y="0"/>
                </Anchor>
              </Anchors>
            </Texture>
          </Layer>

          <Layer level="OVERLAY">
            <Texture file="Interface\Minimap\MiniMap-TrackingBorder">
              <Size x="53" y="53"/>
              <Anchors>
                <Anchor point="TOPLEFT">
                  <Offset>
                    <AbsDimension x="0" y="0" />
                  </Offset>
                </Anchor>
              </Anchors>
            </Texture>
          </Layer>
        </Layers>

        <HighlightTexture alphaMode="ADD" file="Interface\Minimap\UI-Minimap-ZoomButton-Highlight"/>

        <Scripts>
		<OnClick>
		  if arg1 == "LeftButton" and not IsControlKeyDown() then
			TurtleRP_MinimapIcon:StopMovingOrSizing()
			TurtleRP.movingMinimapButton = nil
			TurtleRP.OpenAdmin()
		  end
		</OnClick>

		<OnMouseDown>
		  TurtleRP_MinimapIcon:StopMovingOrSizing()

		  if arg1 == "LeftButton" and IsControlKeyDown() then
			TurtleRP.movingMinimapButton = 1
			TurtleRP_MinimapIcon:StartMoving()
		  else
			TurtleRP.movingMinimapButton = nil
		  end
		</OnMouseDown>

		<OnMouseUp>
		  TurtleRP_MinimapIcon:StopMovingOrSizing()

		  if TurtleRP.movingMinimapButton == 1 then
			TurtleRP.SaveMinimapIconPosition()
		  end

		  TurtleRP.movingMinimapButton = nil
		</OnMouseUp>
        </Scripts>
      </Button>
    </Frames>
  </Frame>

</Ui>
